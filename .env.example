# Telegram Bot API token from @BotFather. Required for the bot to start.
BOT_TOKEN=1234567890:replace-with-your-telegram-bot-token

# Neon Postgres connection string. Required for persistent profiles, coins,
# leaderboards, cricket matches, shop, and cooldowns.
DATABASE_URL=postgresql://user:password@ep-example.us-east-1.aws.neon.tech/neondb?sslmode=require

# Optional: maximum Neon/Postgres connections used by the app.
PGPOOL_MAX=5

# HTTP port for Express. Render and most PaaS providers set this automatically.
PORT=3000

# Public hostname used to build Telegram Web App/Mini App URLs and self-ping on Render.
# On Render this is usually injected automatically, for example: undercover-bot.onrender.com
RENDER_EXTERNAL_HOSTNAME=your-app.onrender.com
